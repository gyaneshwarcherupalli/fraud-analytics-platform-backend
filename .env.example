# Application Settings
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Database Configuration - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fraud_analytics
DB_USER=fraud_admin
DB_PASSWORD=change_me

# Snowflake Configuration
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=change_me
SNOWFLAKE_DATABASE=fraud_analytics
SNOWFLAKE_SCHEMA=public
SNOWFLAKE_WAREHOUSE=compute_wh

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_ALERTS=alerts
KAFKA_CONSUMER_GROUP=fraud-detector-group
KAFKA_CLIENT_ID=fraud-analytics-backend
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=True
KAFKA_AUTO_COMMIT_INTERVAL_MS=5000
KAFKA_MAX_POLL_RECORDS=500
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=5
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_LINGER_MS=10
KAFKA_PRODUCER_COMPRESSION_TYPE=gzip

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
AWS_S3_BUCKET=fraud-analytics-bucket

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log

# Email/Alerts
ALERT_EMAIL_ENABLED=False
ALERT_EMAIL_FROM=noreply@frauddetection.com
ALERT_SMTP_SERVER=smtp.gmail.com
ALERT_SMTP_PORT=587
